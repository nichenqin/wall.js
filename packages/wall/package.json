{
  "name": "wall.js",
  "version": "2.0.0",
  "description": "Modern fullpage piling — zero dependency, TypeScript, destroyable",
  "type": "module",
  "main": "./dist/wall.cjs",
  "module": "./dist/wall.js",
  "types": "./dist/wall.d.ts",
  "unpkg": "./dist/wall.iife.js",
  "jsdelivr": "./dist/wall.iife.js",
  "exports": {
    ".": {
      "types": "./dist/wall.d.ts",
      "import": "./dist/wall.js",
      "require": "./dist/wall.cjs",
      "default": "./dist/wall.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "pnpm build"
  },
  "keywords": [
    "fullpage",
    "fullscreen",
    "scrolling",
    "scroll",
    "piling",
    "sections",
    "typescript"
  ],
  "author": {
    "name": "nichenqin",
    "email": "nichenqin@hotmail.com",
    "url": "https://github.com/nichenqin"
  },
  "homepage": "https://github.com/nichenqin/wall.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/nichenqin/wall.js.git",
    "directory": "packages/wall"
  },
  "bugs": {
    "url": "https://github.com/nichenqin/wall.js/issues"
  },
  "license": "MIT",
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=18"
  }
}
