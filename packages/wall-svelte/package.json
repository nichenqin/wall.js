{
  "name": "@wall.js/svelte",
  "version": "2.0.0",
  "description": "Svelte bindings for wall.js — <Wall>, <WallSection>, <WallSlide>",
  "type": "module",
  "svelte": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "svelte": "./dist/index.js",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "svelte-package -i src -o dist",
    "dev": "svelte-package -i src -o dist --watch",
    "typecheck": "svelte-check --tsconfig ./tsconfig.json",
    "clean": "rm -rf dist",
    "prepublishOnly": "pnpm build"
  },
  "keywords": [
    "wall.js",
    "fullpage",
    "svelte",
    "scrolling",
    "fullscreen"
  ],
  "author": {
    "name": "nichenqin",
    "email": "nichenqin@hotmail.com",
    "url": "https://github.com/nichenqin"
  },
  "homepage": "https://github.com/nichenqin/wall.js/tree/master/packages/wall-svelte",
  "repository": {
    "type": "git",
    "url": "https://github.com/nichenqin/wall.js.git",
    "directory": "packages/wall-svelte"
  },
  "bugs": {
    "url": "https://github.com/nichenqin/wall.js/issues"
  },
  "license": "MIT",
  "peerDependencies": {
    "svelte": ">=5",
    "wall.js": ">=2.0.0"
  },
  "devDependencies": {
    "@sveltejs/package": "^2.5.4",
    "@sveltejs/vite-plugin-svelte": "^7.2.0",
    "svelte": "^5.56.4",
    "svelte-check": "^4.4.6",
    "typescript": "^6.0.3",
    "vite": "^8.1.4",
    "wall.js": "workspace:*"
  },
  "engines": {
    "node": ">=18"
  }
}
