{
  "name": "@wall.js/vue",
  "version": "2.0.0",
  "description": "Vue bindings for wall.js — <Wall>, <WallSection>, <WallSlide>",
  "type": "module",
  "main": "./dist/wall-vue.cjs",
  "module": "./dist/wall-vue.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/wall-vue.js",
      "require": "./dist/wall-vue.cjs",
      "default": "./dist/wall-vue.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "vite build && vue-tsc --declaration --emitDeclarationOnly -p tsconfig.build.json",
    "dev": "vite build --watch",
    "typecheck": "vue-tsc --noEmit -p tsconfig.json",
    "clean": "rm -rf dist",
    "prepublishOnly": "pnpm build"
  },
  "keywords": [
    "wall.js",
    "fullpage",
    "vue",
    "scrolling",
    "fullscreen"
  ],
  "author": {
    "name": "nichenqin",
    "email": "nichenqin@hotmail.com",
    "url": "https://github.com/nichenqin"
  },
  "homepage": "https://github.com/nichenqin/wall.js/tree/master/packages/wall-vue",
  "repository": {
    "type": "git",
    "url": "https://github.com/nichenqin/wall.js.git",
    "directory": "packages/wall-vue"
  },
  "bugs": {
    "url": "https://github.com/nichenqin/wall.js/issues"
  },
  "license": "MIT",
  "peerDependencies": {
    "vue": ">=3.4",
    "wall.js": ">=2.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.7",
    "typescript": "^6.0.3",
    "vite": "^8.1.4",
    "vue": "^3.5.39",
    "vue-tsc": "^3.2.6",
    "wall.js": "workspace:*"
  },
  "engines": {
    "node": ">=18"
  }
}
